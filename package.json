{
  "name": "@t-tommasi/schemaforge",
  "version": "0.1.0",
  "type": "module",
  "description": "A TypeScript library for converting messy structured data into normalized schema-ready rows.",
  "main": "./dist/index.js",
  "license": "Apache-2.0",
  "author": "Thomas Tommasi",
  "types": "./dist/index.d.ts",
    "repository": {
    "type": "git",
    "url": "git+https://github.com/T-Tommasi/schemaForge.git"
  },
  "keywords": [
    "etl",
    "csv",
    "xml",
    "schema",
    "data-transformation",
    "normalization",
    "typescript"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./utils/*": "./dist/utils/*.js",
    "./plugins/*": "./dist/plugins/*.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "npx tsx test.ts",
    "test:watch": "tsc --watch",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "check": "npm run lint && npm run test && npm run build",
    "prepublishOnly": "npm run check"
  },
  "dependencies": {
    "fast-xml-parser": "^5.7.2",
    "papaparse": "^5.4.1",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/papaparse": "^5.3.15",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.3.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.31.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
